{
  "expo": {
    "name": "Limby App",
    "slug": "limby-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A6B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.limby.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2A6B"
      },
      "package": "com.limby.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application accède à vos photos pour publier vos annonces."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permettre à Limby d'accéder à votre position."
        }
      ],
      "expo-font"
    ],
    "scheme": "limby",
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://limby01-production.up.railway.app/api",
      "router": {},
      "eas": {
        "projectId": "5061cfac-c297-4824-9158-f8961daca12d"
      }
    }
  }
}
